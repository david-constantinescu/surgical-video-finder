# Optional: official YouTube Data API (higher quota/reliability; not required)
YOUTUBE_API_KEY=
# Optional: Vimeo API token (inline Vimeo only when set)
VIMEO_TOKEN=
# Contact email for PubMed E-utilities (no API key needed)
NCBI_CONTACT_EMAIL=dev@localhost

# No-key YouTube search via public Piped/Invidious instances (comma-separated fallbacks)
NOKEY_SEARCH_INSTANCES=https://pipedapi.kavin.rocks,https://pipedapi.adminforge.de

INLINE_CACHE_TTL_HOURS=168
YOUTUBE_MAX_RESULTS=8
VIMEO_MAX_RESULTS=6
PUBMED_MAX_RESULTS=6

# Search tuning
SEMANTIC_MIN_SIMILARITY=0.4

# Flask
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
